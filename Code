    followers = st.number_input("Followers", min_value=0)
    posts = st.number_input("Posts", min_value=0)
    bio = st.number_input("Bio Length", min_value=0)

with col2:
    following = st.number_input("Following", min_value=0)
    age = st.number_input("Account Age (days)", min_value=0)

# Button
if st.button("Check Profile"):
    try:
        features = pd.DataFrame([[followers, following, posts, bio, age]],
                                columns=["followers", "following", "posts", "bio_length", "account_age"])

        result = model.predict(features)[0]
        prob = model.predict_proba(features)[0]
        confidence = max(prob) * 100

        st.markdown("---")

        if result == 1:
            st.error(f" {username} ({platform}) is a Fake Profile\n\nConfidence: {confidence:.2f}%")
        else:
            st.success(f" {username} ({platform}) is a Real Profile\n\nConfidence: {confidence:.2f}%")

